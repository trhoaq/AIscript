{
  "dataset_format": "coco",
  "img_size": 320,
  "batch_size": 4,
  "num_workers": 4,
  "eval_interval": 1,
  "p_mosaic": 0.5,
  "p_mixup": 0.5,
  "lr": 0.0001,
  "weight_decay": 0.0001,
  "epochs": 200,
  "use_pretrained_student_weights": false,
  "student_pretrained_weights": "models/student_pretrained.pth",
  "load_student_checkpoint": false,
  "student_checkpoint": "models/student_checkpoint.pth",
  "student_best_model_path": "models/best_model.pth",
  "student_final_model_path": "models/final_model.pth",
  "student_interval_checkpoint_dir": "models",
  "score_thresh": 0.05,
  "eval_score_thresh": 0.05,
  "eval_pre_nms_topk": 400,
  "eval_max_detections": 100,
  "early_stopping_patience": 20,
  "use_kd": true,
  "load_teacher_checkpoint": false,
  "use_pretrained_teacher_backbone": true,
  "teacher_checkpoint": "models/teacher_best_model.pth",
  "teacher_best_model_path": "models/teacher_best_model.pth",
  "teacher_final_model_path": "models/teacher_final_model.pth",
  "teacher_interval_checkpoint_dir": "models",
  "wandb_project": "AIscript-Object-Detection",
  "wandb_run_name": "GhostNet-SSD-v1"
}
