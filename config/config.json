{
  "dataset_format": "voc",
  "img_size": 320,
  "batch_size": 4,
  "num_workers": 2,
  "seed": 42,
  "deterministic": false,
  "eval_interval": 1,
  "p_mosaic": 0.5,
  "p_mixup": 0.5,
  "lr": 0.0001,
  "weight_decay": 0.001,
  "epochs": 100,
  "student_width": 1.0,
  "load_student_checkpoint": false,
  "student_checkpoint": "models/kd_student/best_model.pth",
  "student_best_model_path": "models/kd_student/best_model.pth",
  "student_final_model_path": "models/kd_student/final_model.pth",
  "student_interval_checkpoint_dir": "models/kd_student/cp",
  "voc_auto_split": true,
  "voc_val_ratio": 0.2,
  "score_thresh": 0.3,
  "eval_score_thresh": 0.3,
  "eval_pre_nms_topk": 400,
  "eval_max_detections": 100,
  "early_stopping_patience": 20,
  "use_kd": true,
  "load_teacher_checkpoint": true,
  "kd_teacher_model_path": "models/teacher/best_model.pth",
  "teacher_best_model_path": "models/teacher/best_model.pth",
  "teacher_final_model_path": "models/teacher/final_model.pth",
  "teacher_interval_checkpoint_dir": "models/teacher/cp",
  "wandb_project": "AIscript-Object-Detection",
  "wandb_run_name": "GhostNet-SSD-v1"
}
