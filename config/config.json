{
  "dataset_format": "coco",
  "img_size": 512,
  "batch_size": 8,
  "num_workers": 4,
  "seed": 42,
  "deterministic": false,
  "eval_interval": 1,
  "p_mosaic": 0.5,
  "p_mixup": 0,
  "lr": 0.0001,
  "weight_decay": 0.001,
  "warmup_epochs": 5,
  "epochs": 100,
  "student_model": "cnn",
  "student_width": 1.0,
  "student_pretrained_backbone": true,
  "student_cnn_base_channels": [24, 48, 96],
  "student_cnn_fpn_channels": 64,
  "student_cnn_fc_dim": 256,
  "student_cnn_stem_channels": [16, 32],
  "student_cnn_head_dropout": 0.1,
  "student_cnn_head_num_convs": 3,
  "student_cnn_head_depthwise": true,
  "student_cnn_fcos_strides": [4, 8, 16, 32, 64, 128],
  "student_cnn_fcos_ranges": [[0, 32], [32, 64], [64, 128], [128, 256], [256, 512], [512, 1e8]],
  "student_cnn_aspect_ratios": [[1, 2], [1, 2, 3], [1, 2, 3], [1, 2, 3], [1, 2], [1, 2]],
  "student_cnn_s_min": 0.03,
  "student_cnn_s_max": 0.95,
  "load_student_checkpoint": false,
  "student_checkpoint": "models/kd_student/best_model.pth",
  "student_best_model_path": "models/kd_student/best_model.pth",
  "student_final_model_path": "models/kd_student/final_model.pth",
  "student_interval_checkpoint_dir": "models/kd_student/cp",
  "voc_auto_split": true,
  "voc_val_ratio": 0.2,
  "score_thresh": 0.5,
  "eval_score_thresh": 0.5,
  "nms_thresh": 0.6,
  "eval_pre_nms_topk": 400,
  "eval_max_detections": 100,
  "early_stopping_patience": 10,
  "use_kd": false,
  "load_teacher_checkpoint": true,
  "kd_teacher_model_path": "models/teacher/best_model.pth",
  "teacher_best_model_path": "models/teacher/best_model.pth",
  "teacher_final_model_path": "models/teacher/final_model.pth",
  "teacher_interval_checkpoint_dir": "models/teacher/cp",
  "wandb_project": "AIscript-Object-Detection",
  "wandb_run_name": "GhostNet-SSD-v1"
}
